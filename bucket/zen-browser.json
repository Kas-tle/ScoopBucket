{
    "version": "1.21.6b",
    "description": "A open-source browser based on the Firefox engine",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "notes": [
        "To set profile 'Scoop' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Zen Browser Profile Manager', choose 'Scoop' then click 'Start Zen Browser'.",
        "  - Visit 'about:profiles' page in Zen Browser to check *DEFAULT* profile.",
        "  - Run 'zen-fix-links' once Zen is set as the default browser to ensure links open in the Scoop profile",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.6b/zen.installer.exe#/dl.7z",
            "hash": "bee30f718d1c595986cfd246edf094d323fa5b34eee9aefbefc2524546dfdf21"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.6b/zen.installer-arm64.exe#/dl.7z",
            "hash": "654b959e755c6bf159cde77ccf865e5f1c443e673207f3b9228baef5eb903ff7"
        }
    },
    "pre_install": [
        "$scriptLines = @(",
        "  '$appDir = Split-Path $PSScriptRoot -Parent',",
        "  '$targetExe = Join-Path $appDir \"current\\zen.exe\"',",
        "  '$newCmd = ''\"'' + $targetExe + ''\" -osint -url \"%1\"''',",
        "  '$newBaseCmd = ''\"'' + $targetExe + ''\"''',",
        "  '\"Firefox*\", \"Zen*\" | ForEach-Object {',",
        "  '  Get-ChildItem -Path \"HKCU:\\Software\\Classes\\$_\" -ErrorAction SilentlyContinue | ForEach-Object {',",
        "  '    $cmdKey = Join-Path $_.PSPath \"shell\\open\\command\"',",
        "  '    if (Test-Path $cmdKey) {',",
        "  '      $currentCmd = Get-ItemPropertyValue -Path $cmdKey -Name \"(default)\" -ErrorAction SilentlyContinue',",
        "  '      if ($currentCmd -match \"zen\\.exe\") { Set-ItemProperty -Path $cmdKey -Name \"(default)\" -Value $newCmd }',",
        "  '    }',",
        "  '  }',",
        "  '}',",
        "  'Get-ChildItem -Path \"HKCU:\\Software\\Clients\\StartMenuInternet\" -ErrorAction SilentlyContinue | ForEach-Object {',",
        "  '  $appName = Get-ItemPropertyValue -Path $_.PSPath -Name \"(default)\" -ErrorAction SilentlyContinue',",
        "  '  if ($appName -match \"Zen Browser\") {',",
        "  '    $cmdKey = Join-Path $_.PSPath \"shell\\open\\command\"',",
        "  '    if (Test-Path $cmdKey) { Set-ItemProperty -Path $cmdKey -Name \"(default)\" -Value $newBaseCmd }',",
        "  '  }',",
        "  '}',",
        "  'Write-Host \"Zen Browser registry keys safely patched to use Scoop current path.\"'",
        ")",
        "Set-Content -Path \"$dir\\zen-fix-links.ps1\" -Value $scriptLines"
    ],
    "post_install": [
        "zen -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}",
        "info 'Forcing Scoop profile as default...'",
        "$pIni = \"$env:APPDATA\\Zen\\profiles.ini\"",
        "$iIni = \"$env:APPDATA\\Zen\\installs.ini\"",
        "if (Test-Path $pIni) {",
        "  $lines = Get-Content $pIni",
        "  $out = @(); $isScoop = $false",
        "  foreach ($line in $lines) {",
        "    if ($line.StartsWith('[Profile')) { $isScoop = $false }",
        "    if ($line -eq 'Name=Scoop') { $isScoop = $true }",
        "    if ($line -eq 'Default=1') { continue }",
        "    $out += $line",
        "    if ($isScoop -and $line.StartsWith('Path=')) { $out += 'Default=1' }",
        "  }",
        "  Set-Content -Path $pIni -Value $out",
        "}",
        "if (Test-Path $iIni) { Remove-Item $iIni -Force }",
        "info 'Running registry patch (will apply if Zen is already default)...'",
        "& \"$dir\\zen-fix-links.ps1\""
    ],
    "extract_dir": "core",
    "bin": [
        [
            "zen.exe",
            "zen",
            "-P Scoop"
        ],
        "zen-fix-links.ps1"
    ],
    "shortcuts": [
        [
            "zen.exe",
            "Zen Browser",
            "-P Scoop"
        ],
        [
            "zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z"
            }
        }
    }
}
