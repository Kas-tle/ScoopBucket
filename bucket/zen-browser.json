{
    "version": "1.21.1b",
    "description": "A open-source browser based on the Firefox engine",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "notes": [
        "To set profile 'Scoop' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Zen Browser Profile Manager', choose 'Scoop' then click 'Start Zen Browser'.",
        "  - Visit 'about:profiles' page in Zen Browser to check *DEFAULT* profile.",
        "  - Run 'zen-fix-links' once Zen is set as the default browser to ensure links open in the Scoop profile",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.1b/zen.installer.exe#/dl.7z",
            "hash": "ad23d44d0a23004580c4497fc3ac245a8f4a669846e8919e2b4634ffaac657fc"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.1b/zen.installer-arm64.exe#/dl.7z",
            "hash": "a17792f2d3b1440899cb94b5beb2ae3c65ae01cc7ef390dfefd7e6902653412a"
        }
    },
    "pre_install": [
        "$scriptLines = @(",
        "  '$appDir = Split-Path $PSScriptRoot -Parent',",
        "  '$targetExe = Join-Path $appDir \"current\\core\\zen.exe\"',",
        "  '$newCmd = ''\"'' + $targetExe + ''\" -osint -url \"%1\"''',",
        "  '$newBaseCmd = ''\"'' + $targetExe + ''\"''',",
        "  'Get-ChildItem -Path HKCU:\\Software\\Classes\\Zen* -ErrorAction SilentlyContinue | ForEach-Object {',",
        "  '  $cmdKey = Join-Path $_.PSPath \"shell\\open\\command\"',",
        "  '  if (Test-Path $cmdKey) { Set-ItemProperty -Path $cmdKey -Name \"(default)\" -Value $newCmd }',",
        "  '}',",
        "  'Get-ChildItem -Path HKCU:\\Software\\Clients\\StartMenuInternet\\Zen* -ErrorAction SilentlyContinue | ForEach-Object {',",
        "  '  $cmdKey = Join-Path $_.PSPath \"shell\\open\\command\"',",
        "  '  if (Test-Path $cmdKey) { Set-ItemProperty -Path $cmdKey -Name \"(default)\" -Value $newBaseCmd }',",
        "  '}',",
        "  'Write-Host \"Zen Browser registry keys patched to use Scoop current path.\"'",
        ")",
        "Set-Content -Path \"$dir\\zen-fix-links.ps1\" -Value $scriptLines"
    ],
    "post_install": [
        "zen -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}",
        "info 'Running registry patch (will apply if Zen is already default)...'",
        "& \"$dir\\zen-fix-links.ps1\""
    ],
    "extract_dir": "core",
    "bin": [
        [
            "zen.exe",
            "zen",
            "-P Scoop"
        ],
        "zen-fix-links.ps1"
    ],
    "shortcuts": [
        [
            "zen.exe",
            "Zen Browser",
            "-P Scoop"
        ],
        [
            "zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z"
            }
        }
    }
}
